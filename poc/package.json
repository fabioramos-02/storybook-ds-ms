{
  "name": "@design-system-ms/ds-sis",
  "version": "0.3.1",
  "description": "DS-MS — Design System de Mato Grosso do Sul. Tokens (JSON -> Style Dictionary) + componentes CSS+HTML/Web Components, fiéis ao Figma oficial. 41/41 componentes implementados, tokens 100% sincronizados com fidelidade Figma (ver docs/08-proximos-passos.md).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fabioramos-02/DS-MS-Design-System.git",
    "directory": "poc"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/js/ds-sis.js",
  "module": "dist/js/ds-sis.js",
  "exports": {
    "./css": "./dist/css/ds-sis.css",
    "./dist/css/ds-sis.css": "./dist/css/ds-sis.css",
    ".": "./dist/js/ds-sis.js",
    "./tokens": "./dist/json/tokens.json"
  },
  "scripts": {
    "tokens": "style-dictionary build --config style-dictionary.config.js",
    "build": "npm run tokens && node scripts/build-css.js && vite build --config vite.lib.config.js",
    "storybook": "npm run tokens && storybook dev -p 6006",
    "build-storybook": "npm run tokens && storybook build"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/web-components-vite": "^8.6.0",
    "lit": "^3.1.4",
    "storybook": "^8.6.0",
    "style-dictionary": "^3.9.2",
    "vite": "^5.4.0"
  }
}
